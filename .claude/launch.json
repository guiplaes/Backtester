{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "brain-flow-static",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8765", "--directory", "1_PROYECTO"],
      "port": 8765
    },
    {
      "name": "brain-dashboard",
      "runtimeExecutable": "powershell",
      "runtimeArgs": ["-NoProfile", "-Command", "while($true){Start-Sleep 3600}"],
      "port": 5858
    },
    {
      "name": "grid-dashboard",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "streamlit", "run", "grid_manager/dashboard.py", "--server.port", "8503", "--server.address", "127.0.0.1", "--server.headless", "true", "--browser.gatherUsageStats", "false"],
      "port": 8503
    }
  ]
}
