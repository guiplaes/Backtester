//@version=6
strategy("Mean-Rev Averaging Universal",
     overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.fixed,
     default_qty_value=1,
     pyramiding=4,
     commission_type=strategy.commission.cash_per_order,
     commission_value=0.20,
     slippage=1,
     calc_on_every_tick=false,
     process_orders_on_close=true)

// ==================== INPUTS ====================
// Adapta aquests params al TF/actiu que tries:
// - XAUUSD H4: ma_period=200, level1=-0.5, level2=-1.0, level3=-1.5, level4=-2.0, stop_z=-3.0
// - EURCHF H1: ma_period=500, level1=-0.5, level2=-1.5, level3=-2.5, stop_z=-3.5
// - D1 qualsevol: ma_period=50, level1=-1.0, level2=-2.0, level3=-3.0, stop_z=-4.0
//
// REGLA: ma_period ha de representar ~25-50 dies en bars del TF actual

ma_period = input.int(200, "SMA Period", minval=20, group="Indicador",
     tooltip="Bars de la mitjana. ~25-50 dies del TF: H4=200, H1=500, M30=800, D1=50.")

level1 = input.float(-0.5, "Entry Level 1 (z)", group="Entrades graduals",
     tooltip="Primera entrada quan z-score arriba aquest nivell")
level2 = input.float(-1.0, "Entry Level 2 (z)", group="Entrades graduals")
level3 = input.float(-1.5, "Entry Level 3 (z)", group="Entrades graduals")
level4 = input.float(-2.0, "Entry Level 4 (z)", group="Entrades graduals")

stop_z = input.float(-3.0, "Stop Loss (z)", group="Sortida",
     tooltip="Tanca tot si z arriba aquí (catastrofe regime change)")
max_bars_hold = input.int(500, "Max bars hold", group="Sortida",
     tooltip="Time-stop opcional")

trade_long = input.bool(true, "Operar LONG (z negatiu)", group="Direcció")
trade_short = input.bool(false, "Operar SHORT (z positiu)", group="Direcció",
     tooltip="Activar si l'actiu també revert a la baixa de la mitjana")

// ==================== INDICADORS ====================
sma = ta.sma(close, ma_period)
std = ta.stdev(close, ma_period)
z = std > 0 ? (close - sma) / std : 0.0

// ==================== PLOTS ====================
plot(sma, "SMA (target)", color=color.yellow, linewidth=2)

// Bands long
plot(trade_long ? sma + std * level1 : na, "L1 long", color=color.new(color.green, 60), linewidth=1)
plot(trade_long ? sma + std * level2 : na, "L2 long", color=color.new(color.green, 40), linewidth=1)
plot(trade_long ? sma + std * level3 : na, "L3 long", color=color.new(color.green, 20), linewidth=1)
plot(trade_long ? sma + std * level4 : na, "L4 long", color=color.new(color.green, 0),  linewidth=2)
plot(trade_long ? sma + std * stop_z : na, "STOP long", color=color.red, linewidth=2)

// Bands short (mirror)
plot(trade_short ? sma - std * level1 : na, "L1 short", color=color.new(color.red, 60), linewidth=1)
plot(trade_short ? sma - std * level2 : na, "L2 short", color=color.new(color.red, 40), linewidth=1)
plot(trade_short ? sma - std * level3 : na, "L3 short", color=color.new(color.red, 20), linewidth=1)
plot(trade_short ? sma - std * level4 : na, "L4 short", color=color.new(color.red, 0),  linewidth=2)
plot(trade_short ? sma - std * stop_z : na, "STOP short", color=color.fuchsia, linewidth=2)

// ==================== STATE ====================
var bool L1_long = false
var bool L2_long = false
var bool L3_long = false
var bool L4_long = false
var bool L1_short = false
var bool L2_short = false
var bool L3_short = false
var bool L4_short = false

in_long = strategy.position_size > 0
in_short = strategy.position_size < 0
in_pos = in_long or in_short

// ==================== ENTRY LONG ====================
if trade_long and not in_short
    if not L1_long and z <= level1 and barstate.isconfirmed
        strategy.entry("L1L", strategy.long, qty=1, comment=str.format("L1 z={0,number,0.00}", z))
        L1_long := true
    if L1_long and not L2_long and z <= level2 and barstate.isconfirmed
        strategy.entry("L2L", strategy.long, qty=1, comment=str.format("L2 z={0,number,0.00}", z))
        L2_long := true
    if L2_long and not L3_long and z <= level3 and barstate.isconfirmed
        strategy.entry("L3L", strategy.long, qty=1, comment=str.format("L3 z={0,number,0.00}", z))
        L3_long := true
    if L3_long and not L4_long and z <= level4 and barstate.isconfirmed
        strategy.entry("L4L", strategy.long, qty=1, comment=str.format("L4 z={0,number,0.00}", z))
        L4_long := true

// ==================== ENTRY SHORT ====================
if trade_short and not in_long
    if not L1_short and z >= -level1 and barstate.isconfirmed
        strategy.entry("L1S", strategy.short, qty=1, comment=str.format("L1 z={0,number,0.00}", z))
        L1_short := true
    if L1_short and not L2_short and z >= -level2 and barstate.isconfirmed
        strategy.entry("L2S", strategy.short, qty=1, comment=str.format("L2 z={0,number,0.00}", z))
        L2_short := true
    if L2_short and not L3_short and z >= -level3 and barstate.isconfirmed
        strategy.entry("L3S", strategy.short, qty=1, comment=str.format("L3 z={0,number,0.00}", z))
        L3_short := true
    if L3_short and not L4_short and z >= -level4 and barstate.isconfirmed
        strategy.entry("L4S", strategy.short, qty=1, comment=str.format("L4 z={0,number,0.00}", z))
        L4_short := true

// ==================== EXIT ====================
// Time held (bars since first entry)
bars_in_pos = in_pos ? bar_index - strategy.opentrades.entry_bar_index(0) : 0

// LONG exits
if in_long
    target_hit = close >= sma
    stop_hit = z <= stop_z
    time_hit = bars_in_pos >= max_bars_hold
    if target_hit
        strategy.close_all(comment="TARGET (return SMA)")
        L1_long := false
        L2_long := false
        L3_long := false
        L4_long := false
    else if stop_hit
        strategy.close_all(comment="STOP (z<" + str.tostring(stop_z, "0.0") + ")")
        L1_long := false
        L2_long := false
        L3_long := false
        L4_long := false
    else if time_hit
        strategy.close_all(comment="TIME OUT")
        L1_long := false
        L2_long := false
        L3_long := false
        L4_long := false

// SHORT exits
if in_short
    target_hit_s = close <= sma
    stop_hit_s = z >= -stop_z
    time_hit_s = bars_in_pos >= max_bars_hold
    if target_hit_s
        strategy.close_all(comment="TARGET S (return SMA)")
        L1_short := false
        L2_short := false
        L3_short := false
        L4_short := false
    else if stop_hit_s
        strategy.close_all(comment="STOP S (z>" + str.tostring(-stop_z, "0.0") + ")")
        L1_short := false
        L2_short := false
        L3_short := false
        L4_short := false
    else if time_hit_s
        strategy.close_all(comment="TIME OUT S")
        L1_short := false
        L2_short := false
        L3_short := false
        L4_short := false

// ==================== INFO TABLE ====================
var table info_table = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 80), border_width=1)
if barstate.islast
    table.cell(info_table, 0, 0, "z-score", text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 0, str.tostring(z, "0.00"), text_color = z < 0 ? color.lime : color.red, text_size=size.small)
    table.cell(info_table, 0, 1, "SMA", text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 1, str.tostring(sma, format.mintick), text_color=color.yellow, text_size=size.small)
    table.cell(info_table, 0, 2, "Position", text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 2, in_long ? "LONG x" + str.tostring(strategy.opentrades) : in_short ? "SHORT x" + str.tostring(strategy.opentrades) : "FLAT",
         text_color = in_long ? color.lime : in_short ? color.red : color.gray, text_size=size.small)
    table.cell(info_table, 0, 3, "Bars held", text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 3, str.tostring(bars_in_pos), text_color=color.white, text_size=size.small)
    table.cell(info_table, 0, 4, "Levels hit L", text_color=color.white, text_size=size.small)
    levels_hit_l = (L1_long?"1":"") + (L2_long?"2":"") + (L3_long?"3":"") + (L4_long?"4":"")
    table.cell(info_table, 1, 4, levels_hit_l == "" ? "-" : levels_hit_l, text_color=color.lime, text_size=size.small)
    table.cell(info_table, 0, 5, "Levels hit S", text_color=color.white, text_size=size.small)
    levels_hit_s = (L1_short?"1":"") + (L2_short?"2":"") + (L3_short?"3":"") + (L4_short?"4":"")
    table.cell(info_table, 1, 5, levels_hit_s == "" ? "-" : levels_hit_s, text_color=color.red, text_size=size.small)
